generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id            Int      @id @default(autoincrement())
  departmentId  Int?
  name          String
  email         String   @unique
  contactNumber String?
  passwordHash  String   @default("")
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department      Department? @relation(fields: [departmentId], references: [id])
  assignedTasks    Task[]   @relation("TaskAssignee")
  tasksCreated     Task[]   @relation("TaskCreator")
  taskLogs         TaskLog[] @relation("TaskLogActor")
  taskNotifications TaskNotification[]
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  people   Person[]
  tasks    Task[]
}

model Task {
  id               Int          @id @default(autoincrement())
  createdByPersonId Int?
  departmentId     Int?
  title            String
  description      String?
  assignedPersonId Int?
  status           TaskStatus   @default(TODO)
  priority         TaskPriority @default(NORMAL)
  sortOrder        Int
  startDate        DateTime?
  completedAt      DateTime?
  version          Int          @default(1)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  createdBy      Person? @relation("TaskCreator", fields: [createdByPersonId], references: [id], onDelete: SetNull)
  department     Department? @relation(fields: [departmentId], references: [id])
  assignedPerson Person? @relation("TaskAssignee", fields: [assignedPersonId], references: [id])
  logs           TaskLog[]
  notifications  TaskNotification[]

  @@index([status, sortOrder])
}

model TaskLog {
  id        Int         @id @default(autoincrement())
  taskId    Int
  actorId   Int?
  type      TaskLogType
  message   String
  metadata  Json?
  createdAt DateTime    @default(now())

  task  Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor Person? @relation("TaskLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

model TaskNotification {
  id          Int      @id @default(autoincrement())
  taskId      Int
  recipientId Int
  actorId     Int?
  taskLogId   Int?
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  recipient Person  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([taskId, recipientId, isRead])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  HIGH
  NORMAL
  LOW
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum TaskLogType {
  TASK_CREATED
  ASSIGNEE_CHANGED
  PRIORITY_CHANGED
  NOTE
}
